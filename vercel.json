{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "yarn build:vercel",
  "outputDirectory": "dist/client",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Language", "value": "en" }
      ]
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/_shell.html" }
  ]
}
